    </div>
    <div class="slabel">Recent Applicants</div>
    <div id="ticketFeed"><div class="loading"><div class="spinner"></div>Loading applicants...</div></div>
  </div>
</div>

<!-- NEWS -->
<div id="news" class="page">
  <div class="container">
    <div class="card">
      <h2>Post an Update</h2>
      <p>Share news with the community.</p>
      <textarea id="newsInput" placeholder="What's new with the project?"></textarea>
      <button class="btn" onclick="addNews()">Post Update</button>
    </div>
    <div class="slabel">Latest Updates</div>
