<script>
// ── JSONBin shared database — all users see the same data ────────────────────
const JSONBIN_KEY = '$2a$10$V/Y8Trs0oSs74J9jIZWctu3T4ho/VKVZ/qEhLuAvkIKVtl7aN5bb.';
const JSONBIN_URL = 'https://api.jsonbin.io/v3/b';

// Master bin stores the IDs of news+tickets bins so all users share the same ones
const MASTER_BIN_ID = '6a3ff956da38895dfe0807e9'; // created once, hardcoded

let _binIds = { news: null, tickets: null };

async function getBinIds() {
  if (_binIds.news && _binIds.tickets) return _binIds;
  try {
    const res = await fetch(`${JSONBIN_URL}/${MASTER_BIN_ID}/latest`, {
      headers: { 'X-Master-Key': JSONBIN_KEY }
    });
    const data = await res.json();
    if (data.record?.news && data.record?.tickets) {
      _binIds = data.record;
      return _binIds;
    }
  } catch {}
  return _binIds;
}

async function ensureBin(type) {
  const ids = await getBinIds();
  if (ids[type]) return ids[type];

  // Create bin for this type
  try {
    const res = await fetch(JSONBIN_URL, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-Master-Key': JSONBIN_KEY,
        'X-Bin-Name': 'rrr-' + type,
        'X-Bin-Private': 'false'
      },
      body: JSON.stringify([])
    });
    const data = await res.json();
    const binId = data.metadata?.id;
    if (binId) {
      _binIds[type] = binId;
      // Save new IDs back to master bin
      await fetch(`${JSONBIN_URL}/${MASTER_BIN_ID}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json', 'X-Master-Key': JSONBIN_KEY },
        body: JSON.stringify(_binIds)
      });
    }
    return binId;
  } catch (e) {
    console.error('ensureBin error', e);
    return null;
  }
}

async function storageGet(key) {
  const type = key.includes('news') ? 'news' : 'tickets';
  const binId = await ensureBin(type);
  if (!binId) return [];
  try {
    const res = await fetch(`${JSONBIN_URL}/${binId}/latest`, {
      headers: { 'X-Master-Key': JSONBIN_KEY }
    });
    const data = await res.json();
    return Array.isArray(data.record) ? data.record : [];
  } catch (e) {
    console.error('storageGet error', e);
    return [];
  }
}

async function storageSet(key, arr) {
  const type = key.includes('news') ? 'news' : 'tickets';
  const binId = await ensureBin(type);
  if (!binId) return;
  try {
    await fetch(`${JSONBIN_URL}/${binId}`, {
      method: 'PUT',
      headers: {
        'Content-Type': 'application/json',
        'X-Master-Key': JSONBIN_KEY
      },
      body: JSON.stringify(arr)
    });
  } catch (e) {
    console.error('storageSet error', e);
  }
}

// ── Page nav ──────────────────────────────────────────────────────────────────
function showPage(id) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('nav button').forEach(b => b.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  document.getElementById('nav-' + id).classList.add('active');
  if (id === 'news') loadNews();
  if (id === 'home') { loadStats(); loadTickets(); }
}

// ── Toast ──────────────────────────────────────────────────────────────────────
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2800);
}

// ── Format time ───────────────────────────────────────────────────────────────
function fmt(ts) {
  return new Date(ts).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric',hour:'2-digit',minute:'2-digit'});
}

// ── Escape HTML ───────────────────────────────────────────────────────────────
function esc(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// ── FAQ ───────────────────────────────────────────────────────────────────────
function toggleFaq(el) { el.classList.toggle('open'); }

// ── NEWS ──────────────────────────────────────────────────────────────────────
async function addNews() {
  const text = document.getElementById('newsInput').value.trim();
  if (!text) { showToast('Write something first.'); return; }
  const news = await storageGet('rrr-news-v1');
  news.unshift({ text, ts: Date.now(), id: Math.random().toString(36).slice(2) });
  await storageSet('rrr-news-v1', news);
  document.getElementById('newsInput').value = '';
  showToast('Update posted!');
  loadNews();
}

async function loadNews() {
  const feed = document.getElementById('newsFeed');
  feed.innerHTML = '<div class="loading"><div class="spinner"></div>Loading...</div>';
  const news = await storageGet('rrr-news-v1');
  if (!news.length) { feed.innerHTML = '<div class="empty"><div class="empty-icon">📰</div><p>No updates yet.</p></div>'; return; }
  feed.innerHTML = news.map(n => `<div class="news-item"><div class="news-content">${esc(n.text)}</div><div class="news-meta">${fmt(n.ts)}</div></div>`).join('');
}

// ── TICKETS ───────────────────────────────────────────────────────────────────
async function loadTickets() {
  const feed = document.getElementById('ticketFeed');
  if (!feed) return;
  feed.innerHTML = '<div class="loading"><div class="spinner"></div>Loading applicants...</div>';
  const tickets = await storageGet('rrr-tickets-v1');
  if (!tickets.length) { feed.innerHTML = '<div class="empty"><div class="empty-icon">🎮</div><p>No applicants yet. Be the first!</p></div>'; return; }
  feed.innerHTML = tickets.map(t => `
    <div class="ticket-item">
      <div class="ticket-top">
        <div class="ticket-user"><div class="ticket-avatar">${esc(t.username[0].toUpperCase())}</div>${esc(t.username)}</div>
        <div class="ticket-badge">Pending</div>
      </div>
      <div class="ticket-reason">${esc(t.reason)}</div>
      <div class="ticket-desc">${esc(t.description)}</div>
      <div class="ticket-time">${fmt(t.ts)}</div>
    </div>`).join('');
}

// ── STATS ─────────────────────────────────────────────────────────────────────
async function loadStats() {
  const [news, tickets] = await Promise.all([storageGet('rrr-news-v1'), storageGet('rrr-tickets-v1')]);
  document.getElementById('statApplicants').textContent = tickets.length;
  document.getElementById('statNews').textContent = news.length;
}

// ── SUCCESS ───────────────────────────────────────────────────────────────────
function goHome() {
  document.getElementById('successOverlay').classList.remove('show');
  showPage('home');
}

// ── BOOT LOCK ─────────────────────────────────────────────────────────────────
document.getElementById('bl-username').addEventListener('input', updateBoot);
document.getElementById('bl-reason').addEventListener('input', updateBoot);
document.getElementById('bl-description').addEventListener('input', updateBoot);

function updateBoot() {
  const u = document.getElementById('bl-username').value.trim();
  const r = document.getElementById('bl-reason').value.trim();
  const d = document.getElementById('bl-description').value.trim();
  const btn = document.getElementById('bl-joinBtn');
  const filled = [!!u, !!r, !!d];
  filled.forEach((v, i) => {
    document.getElementById('dot' + i).classList.toggle('on', v);
  });
  const allFilled = u && r && d;
  btn.classList.toggle('ready', allFilled);
  btn.textContent = allFilled ? '🎮 Join Beta →' : '🔒 Fill out all fields to unlock';
}

async function bootSubmit() {
  const u = document.getElementById('bl-username').value.trim();
  const r = document.getElementById('bl-reason').value.trim();
  const d = document.getElementById('bl-description').value.trim();
  if (!u || !r || !d) {
    const btn = document.getElementById('bl-joinBtn');
    btn.style.animation = 'shake 0.4s ease';
    setTimeout(() => btn.style.animation = '', 400);
    updateBoot();
    return;
  }
  const btn = document.getElementById('bl-joinBtn');
  btn.classList.remove('ready');
  btn.textContent = '⏳ Submitting...';
  try {
    const tickets = await storageGet('rrr-tickets-v1');
    tickets.unshift({ username: u, reason: r, description: d, ts: Date.now(), id: Math.random().toString(36).slice(2) });
    await storageSet('rrr-tickets-v1', tickets);
  } catch(e) { console.error(e); }
  const overlay = document.getElementById('bootLock');
  overlay.style.transition = 'opacity 0.5s';
  overlay.style.opacity = '0';
  setTimeout(() => { overlay.style.display = 'none'; showPage('home'); loadStats(); loadTickets(); }, 500);
}

// ── INIT ──────────────────────────────────────────────────────────────────────
loadStats();
loadTickets();
</script>
