<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Rec Room Revival</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
:root{
  --red:#D62828;--red-dark:#A01A1A;--white:#fff;
  --off:#F4ECEC;--gray:#7A7070;--dark:#120606;--border:#E2D0D0;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Inter',sans-serif;background:var(--off);color:var(--dark);min-height:100vh;}

/* BOOT LOCK */
#bootLock{
  position:fixed;inset:0;z-index:1000;
  background:radial-gradient(ellipse at top,#2a0808 0%,#080202 100%);
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  padding:20px;overflow-y:auto;
}
.bl-logo{
  font-family:'Bebas Neue',sans-serif;font-size:30px;letter-spacing:5px;
  color:#fff;margin-bottom:4px;text-align:center;
}
.bl-logo span{color:var(--red);}
.bl-sub{font-size:10px;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,0.25);margin-bottom:28px;text-align:center;}
.bl-card{
  background:#fff;border-radius:22px;padding:30px 24px 26px;
  width:100%;max-width:400px;
  box-shadow:0 40px 100px rgba(0,0,0,0.7);
  border-top:4px solid var(--red);
}
.bl-head{display:flex;align-items:center;gap:14px;margin-bottom:22px;}
.bl-badge{
  width:50px;height:50px;flex-shrink:0;
  background:linear-gradient(135deg,var(--red),var(--red-dark));
  border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:22px;
}
.bl-head h2{font-family:'Bebas Neue',sans-serif;font-size:28px;letter-spacing:2px;color:var(--dark);line-height:1;margin-bottom:3px;}
.bl-head p{font-size:12px;color:var(--gray);}

/* progress dots */
.bl-dots{display:flex;gap:6px;margin-bottom:20px;}
.bl-dot{flex:1;height:4px;border-radius:2px;background:var(--border);transition:background 0.3s;}
.bl-dot.on{background:var(--red);}

/* fields */
.bl-label{display:block;font-size:10px;font-weight:800;letter-spacing:2px;text-transform:uppercase;color:var(--gray);margin-bottom:5px;}
.bl-inp{
  width:100%;background:var(--off);border:1.5px solid var(--border);
  border-radius:10px;padding:12px 14px;font-family:'Inter',sans-serif;
  font-size:14px;color:var(--dark);outline:none;transition:border-color 0.2s,background 0.2s;
  margin-bottom:14px;
}
.bl-inp:focus{border-color:var(--red);background:#fff;}
.bl-inp.err{border-color:var(--red);background:#fff5f5;}
textarea.bl-inp{min-height:80px;resize:vertical;}

/* join button */
#bl-joinBtn{
  width:100%;padding:15px;border-radius:12px;border:none;
  font-family:'Inter',sans-serif;font-weight:800;font-size:15px;
  cursor:pointer;transition:all 0.25s;
  background:#666;color:rgba(255,255,255,0.6);
}
#bl-joinBtn.ready{
  background:var(--red);color:#fff;
  box-shadow:0 4px 20px rgba(214,40,40,0.4);
  animation:pulse 2s ease-in-out infinite;
}
#bl-joinBtn:active{transform:scale(0.97);}

@keyframes pulse{0%,100%{box-shadow:0 0 0 0 rgba(214,40,40,0.4);}50%{box-shadow:0 0 0 14px rgba(214,40,40,0);}}
@keyframes shake{0%,100%{transform:translateX(0);}25%{transform:translateX(-8px);}75%{transform:translateX(8px);}}
@keyframes spin{to{transform:rotate(360deg);}}
@keyframes popIn{from{transform:scale(0.7);opacity:0;}to{transform:scale(1);opacity:1;}}
@keyframes blink{0%,100%{opacity:1;}50%{opacity:0.3;}}

/* HEADER */
header{
  background:var(--dark);height:56px;display:flex;align-items:center;
  padding:0 20px;position:sticky;top:0;z-index:100;
  border-bottom:2px solid var(--red);
}
.logo{font-family:'Bebas Neue',sans-serif;font-size:26px;letter-spacing:4px;color:#fff;}
.logo span{color:var(--red);}

/* NAV */
nav{
  background:#0a0202;display:flex;overflow-x:auto;
  border-bottom:1px solid rgba(255,255,255,0.06);scrollbar-width:none;
}
nav::-webkit-scrollbar{display:none;}
nav button{
  background:none;border:none;border-bottom:3px solid transparent;
  color:rgba(255,255,255,0.35);font-family:'Inter',sans-serif;
  font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;
  padding:13px 18px;cursor:pointer;transition:all 0.2s;
  white-space:nowrap;margin-bottom:-1px;
}
nav button:hover{color:rgba(255,255,255,0.7);}
nav button.active{color:#fff;border-bottom-color:var(--red);}

/* PAGES */
.page{display:none;}.page.active{display:block;}
.container{max-width:680px;margin:0 auto;padding:22px 16px 60px;}

/* HERO */
.hero{
  background:linear-gradient(135deg,var(--dark) 0%,#2d0808 100%);
  border-radius:18px;padding:34px 26px;margin-bottom:16px;color:#fff;
  position:relative;overflow:hidden;
}
.hero::after{
  content:'RRR';position:absolute;right:-8px;bottom:-18px;
  font-family:'Bebas Neue',sans-serif;font-size:110px;
  color:rgba(255,255,255,0.04);letter-spacing:6px;pointer-events:none;
}
.eyebrow{
  display:inline-flex;align-items:center;gap:6px;
  background:rgba(214,40,40,0.18);border:1px solid rgba(214,40,40,0.35);
  color:#ff8080;font-size:10px;font-weight:700;letter-spacing:2px;
  text-transform:uppercase;padding:4px 12px;border-radius:20px;margin-bottom:14px;
}
.eyebrow::before{content:'';width:6px;height:6px;background:#ff4444;border-radius:50%;animation:blink 1.5s ease-in-out infinite;}
.hero h1{font-family:'Bebas Neue',sans-serif;font-size:42px;letter-spacing:3px;line-height:1;margin-bottom:10px;}
.hero p{color:rgba(255,255,255,0.55);font-size:14px;line-height:1.7;margin-bottom:26px;max-width:360px;}
.stats-row{display:flex;gap:28px;}
.stat-num{font-family:'Bebas Neue',sans-serif;font-size:36px;letter-spacing:2px;line-height:1;}
.stat-label{font-size:10px;text-transform:uppercase;letter-spacing:2px;color:rgba(255,255,255,0.3);margin-top:2px;}

/* CARDS */
.card{background:#fff;border:1px solid var(--border);border-radius:16px;padding:22px;margin-bottom:14px;box-shadow:0 2px 12px rgba(0,0,0,0.05);}
.card h2{font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:2px;color:var(--red);margin-bottom:4px;}
.card p{color:var(--gray);font-size:13px;line-height:1.6;margin-bottom:14px;}

/* INPUTS */
input,textarea{
  width:100%;background:var(--off);border:1.5px solid var(--border);
  border-radius:10px;padding:12px 14px;font-family:'Inter',sans-serif;
  font-size:14px;color:var(--dark);margin-bottom:12px;outline:none;resize:vertical;
  transition:border-color 0.2s;
}
input:focus,textarea:focus{border-color:var(--red);background:#fff;}
textarea{min-height:80px;}

/* BTN */
.btn{
  display:inline-flex;align-items:center;gap:8px;
  background:var(--red);color:#fff;border:none;border-radius:10px;
  padding:12px 22px;font-family:'Inter',sans-serif;font-weight:700;font-size:14px;
  cursor:pointer;transition:background 0.2s,transform 0.1s;
}
.btn:hover{background:var(--red-dark);}
.btn:active{transform:scale(0.98);}

/* SECTION LABEL */
.slabel{
  font-size:10px;font-weight:800;letter-spacing:2.5px;text-transform:uppercase;
  color:var(--gray);margin:18px 0 12px;display:flex;align-items:center;gap:10px;
}
.slabel::after{content:'';flex:1;height:1px;background:var(--border);}

/* NEWS */
.news-item{background:#fff;border:1px solid var(--border);border-left:4px solid var(--red);border-radius:10px;padding:16px 18px;margin-bottom:10px;}
.news-content{font-size:14px;line-height:1.65;white-space:pre-wrap;}
.news-meta{font-size:11px;color:var(--gray);margin-top:8px;}

/* TICKETS */
.ticket-item{background:#fff;border:1px solid var(--border);border-radius:12px;padding:18px;margin-bottom:10px;}
.ticket-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;}
.ticket-user{display:flex;align-items:center;gap:10px;font-weight:700;font-size:14px;}
.ticket-avatar{width:32px;height:32px;background:var(--red);border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:800;font-size:13px;flex-shrink:0;}
.ticket-badge{font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;padding:3px 10px;border-radius:20px;background:#fff0f0;color:var(--red);border:1px solid #ffcccc;}
.ticket-reason{font-size:11px;font-weight:700;color:var(--gray);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:5px;}
.ticket-desc{font-size:13px;line-height:1.6;}
.ticket-time{font-size:11px;color:#c0a8a8;margin-top:8px;}

/* SOCIAL */
.social-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.social-card{background:#fff;border:1px solid var(--border);border-radius:14px;padding:20px 14px;text-align:center;cursor:pointer;transition:all 0.15s;display:flex;flex-direction:column;align-items:center;gap:8px;}
.social-card:hover{transform:translateY(-3px);border-color:var(--red);box-shadow:0 8px 24px rgba(214,40,40,0.1);}
.sicon{width:46px;height:46px;border-radius:12px;display:flex;align-items:center;justify-content:center;}
.sname{font-weight:700;font-size:14px;}
.sdesc{font-size:11px;color:var(--gray);line-height:1.4;}
.sbtn{margin-top:4px;background:var(--red);color:#fff;border:none;border-radius:7px;padding:6px 14px;font-size:12px;font-weight:700;cursor:pointer;}
.sbtn:hover{background:var(--red-dark);}

.disc-banner{background:linear-gradient(135deg,#5865F2,#3d4fd1);border-radius:16px;padding:26px;color:#fff;margin-bottom:16px;display:flex;align-items:center;gap:16px;}
.disc-banner-icon{font-size:40px;flex-shrink:0;}
.disc-banner h2{font-family:'Bebas Neue',sans-serif;font-size:24px;letter-spacing:2px;margin-bottom:5px;}
.disc-banner p{color:rgba(255,255,255,0.7);font-size:13px;line-height:1.5;margin-bottom:12px;}
.btn-disc{display:inline-flex;align-items:center;gap:7px;background:#fff;color:#5865F2;border:none;border-radius:8px;padding:9px 16px;font-weight:700;font-size:13px;cursor:pointer;text-decoration:none;}

/* ROADMAP */
.rm-item{display:flex;gap:14px;position:relative;}
.rm-item:not(:last-child)::before{content:'';position:absolute;left:19px;top:42px;width:2px;height:100%;background:var(--border);}
.rm-dot{width:40px;height:40px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:15px;z-index:1;margin-top:2px;}
.rm-dot.done{background:var(--red);}
.rm-dot.now{background:var(--dark);border:2px solid var(--red);}
.rm-dot.soon{background:var(--off);border:2px solid var(--border);}
.rm-body{padding-bottom:24px;flex:1;}
.rm-phase{font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--gray);margin-bottom:2px;}
.rm-title{font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:1.5px;margin-bottom:4px;}
.rm-desc{font-size:13px;color:var(--gray);line-height:1.6;}
.rm-tag{display:inline-block;font-size:10px;font-weight:700;padding:3px 10px;border-radius:20px;margin-top:6px;letter-spacing:0.5px;}
.t-done{background:#fff0f0;color:var(--red);}
.t-now{background:var(--dark);color:#fff;}
.t-soon{background:var(--off);color:var(--gray);border:1px solid var(--border);}

/* FAQ */
.faq-item{border-bottom:1px solid var(--border);padding:15px 0;cursor:pointer;}
.faq-item:first-child{padding-top:0;}.faq-item:last-child{border:none;padding-bottom:0;}
.faq-q{font-weight:600;font-size:14px;display:flex;justify-content:space-between;align-items:center;gap:12px;user-select:none;}
.faq-arr{color:var(--red);font-size:18px;flex-shrink:0;transition:transform 0.2s;}
.faq-item.open .faq-arr{transform:rotate(90deg);}
.faq-a{font-size:13px;color:var(--gray);line-height:1.7;margin-top:9px;display:none;}
.faq-item.open .faq-a{display:block;}

/* EMPTY / LOADING */
.empty{text-align:center;padding:34px 20px;color:var(--gray);}
.empty-icon{font-size:30px;margin-bottom:10px;opacity:0.4;}
.empty p{font-size:13px;}
.loading{text-align:center;padding:26px;color:var(--gray);font-size:13px;}
.spinner{width:22px;height:22px;border:2px solid var(--border);border-top-color:var(--red);border-radius:50%;animation:spin 0.7s linear infinite;margin:0 auto 10px;}

/* TOAST */
#toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(80px);background:var(--dark);color:#fff;padding:12px 22px;border-radius:10px;font-size:13px;font-weight:600;z-index:999;transition:transform 0.3s;pointer-events:none;border-left:4px solid var(--red);white-space:nowrap;}
#toast.show{transform:translateX(-50%) translateY(0);}

/* SUCCESS */
#successOverlay{display:none;position:fixed;inset:0;background:rgba(8,2,2,0.92);z-index:200;align-items:center;justify-content:center;}
#successOverlay.show{display:flex;}
.suc-box{background:#fff;border-radius:20px;padding:42px 34px;text-align:center;max-width:320px;width:90%;animation:popIn 0.4s cubic-bezier(0.34,1.56,0.64,1);border-top:4px solid var(--red);}
.suc-icon{font-size:46px;margin-bottom:12px;}
.suc-box h2{font-family:'Bebas Neue',sans-serif;font-size:28px;letter-spacing:2px;color:var(--red);margin-bottom:6px;}
.suc-box p{color:var(--gray);font-size:13px;line-height:1.6;margin-bottom:20px;}

/* FOOTER */
footer{background:var(--dark);color:rgba(255,255,255,0.25);text-align:center;padding:26px 20px;font-size:11px;}
.ft-logo{font-family:'Bebas Neue',sans-serif;font-size:20px;color:rgba(255,255,255,0.55);letter-spacing:4px;margin-bottom:10px;}
.ft-logo span{color:var(--red);}
.ft-links{display:flex;justify-content:center;gap:16px;margin:10px 0;flex-wrap:wrap;}
.ft-links a{color:rgba(255,255,255,0.25);font-size:10px;text-decoration:none;cursor:pointer;transition:color 0.2s;letter-spacing:1.5px;text-transform:uppercase;}
.ft-links a:hover{color:var(--red);}

@media(max-width:480px){
  .hero h1{font-size:34px;}
  .social-grid{grid-template-columns:1fr;}
  .disc-banner{flex-direction:column;text-align:center;}
  .bl-card{padding:26px 18px 22px;}
}
</style>
</head>
