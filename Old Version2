    <input id="bl-username" class="bl-inp" placeholder="Your username" maxlength="32">
    <label class="bl-label">Why do you want in?</label>
    <input id="bl-reason" class="bl-inp" placeholder="Short answer" maxlength="80">
    <label class="bl-label">Tell us more</label>
    <textarea id="bl-description" class="bl-inp" placeholder="Why should we pick you?" maxlength="500"></textarea>
    <button id="bl-joinBtn" onclick="bootSubmit()">🔒 Fill out all fields to unlock</button>
  </div>
</div>

<header><div class="logo">REC ROOM <span>REVIVAL</span></div></header>

<nav>
  <button id="nav-home" onclick="showPage('home')" class="active">Home</button>
  <button id="nav-news" onclick="showPage('news')">News</button>
  <button id="nav-community" onclick="showPage('community')">Community</button>
  <button id="nav-roadmap" onclick="showPage('roadmap')">Roadmap</button>
</nav>

<!-- HOME -->
<div id="home" class="page active">
  <div class="container">
    <div class="hero">
      <div class="eyebrow">Beta Now Open</div>
